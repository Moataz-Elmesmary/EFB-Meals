# ─── SMTP (nodemailer) ───
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=changeme
MAIL_FROM=no-reply@efb.eg
# The kitchen mailbox that receives new meal requests
KITCHEN_EMAIL=kitchen@efb.eg

# ─── TEST MODE ───
# When set, EVERY email is redirected to this address with the original
# recipient shown in the subject as [TEST → original@…]. Leave blank in prod.
MAIL_REDIRECT=Moataz.Mahdy@efb.eg

# ─── Microsoft login / Azure AD (SSO) ───
# When both are set the app uses real Microsoft sign-in; otherwise demo mode.
AZURE_CLIENT_ID=
AZURE_TENANT_ID=

# ─── SQL Listener for external MSSQL / SAP ───
MSSQL_HOST=
MSSQL_USER=
MSSQL_PASS=
MSSQL_DB=

# ─── SAP endpoint (Sales Order push) ───
SAP_ENDPOINT=
