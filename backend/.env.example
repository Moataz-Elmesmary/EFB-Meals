# ─── SMTP (nodemailer) ───
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=changeme
# Shared mailbox that sends automated mail (preferably via Microsoft Graph)
MAIL_FROM=efb.apps@efb.eg
# The kitchen mailbox that receives new meal requests
KITCHEN_EMAIL=kitchen@efb.eg

# ─── TEST MODE ───
# When set, EVERY email is redirected to this address with the original
# recipient shown in the subject as [TEST → original@…]. Leave blank in prod.
MAIL_REDIRECT=Moataz.Mahdy@efb.eg

# ─── Microsoft login / Azure AD (SSO) ───
# When both are set the app uses real Microsoft sign-in; otherwise demo mode.
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
# Client secret enables sending automated mail via Microsoft Graph
# (requires Mail.Send Application permission + admin consent).
AZURE_CLIENT_SECRET=

# ─── App database ───
# sqlite (dev, zero-config) or mssql (prod SQL Server)
DB_TYPE=sqlite
# When DB_TYPE=mssql:
MSSQL_HOST=
MSSQL_PORT=1433
MSSQL_USER=
MSSQL_PASSWORD=
MSSQL_DATABASE=EFBMeals
MSSQL_ENCRYPT=false
MSSQL_TRUST_CERT=true

# ─── SAP OUTBOUND integration (middleware job) ───
# The job polls approved requests (sap_document_number = 0), maps each to a SAP
# document, posts it via the API (user/password), then writes back the document
# number / feedback / number_of_try. Auth is user+password, NOT email.
SAP_API_URL=            # e.g. https://host:50000/b1s/v1  (Service Layer)
SAP_API_USER=
SAP_API_PASS=
SAP_COMPANY_DB=         # Service Layer company DB
SAP_DOC_TYPE=Orders     # Orders | ProductionOrders | ...
SAP_OUT_INTERVAL_MIN=5  # how often the middleware sweeps
SAP_TLS_STRICT=false    # true to enforce a valid TLS cert
# Test the middleware end-to-end WITHOUT a real SAP (returns a fake doc number):
SAP_DRY_RUN=false

# ─── (legacy) direct SQL / REST push — superseded by the API above ───
SAP_MSSQL_HOST=
SAP_SALESORDER_TABLE=SalesOrder
SAP_ENDPOINT=
